# Copy to apps/web/.env.local (gitignored) for local overrides.
# Vite exposes only `VITE_*` keys to the client bundle.

# API origin. Empty = use the Vite proxy (http://localhost:8787 via
# vite.config.ts). Set this when running against a non-proxied origin
# (CI, prod, etc.).
VITE_API_URL=http://localhost:8787

# WebSocket origin (NOT proxied by Vite — see vite.config.ts comment).
# Default ws://localhost:8787 ships in apps/web/.env.development.
VITE_API_WS_URL=ws://localhost:8787

# Phase 7: Cloudflare Turnstile site key. Public — safe to commit/build into
# the bundle. The dev value is the documented "always passes" test key.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Phase 7: Cloudflare Web Analytics token. Empty = no tracking (default for
# dev). Production: paste the token from CF dashboard → Analytics → Web
# Analytics → Site settings.
VITE_CF_ANALYTICS_TOKEN=

# Phase 7: canonical site origin used for og:url / og:image at build time.
# Empty = leave OG meta blank. Production: e.g. https://snap-share.pages.dev
VITE_PUBLIC_URL=

# Phase 10.H: Google AdSense client ID, embedded into a site-verification
# meta tag at build time (`<meta name="google-adsense-account">`). Empty
# = empty content attribute (default for dev / preview). Set to e.g.
# `ca-pub-XXXXXXXXXXXXXXXX` once an AdSense account is approved (Phase
# 11+). The actual <ins class="adsbygoogle"> tags and the loader script
# are NOT wired in this phase — only the slot reservation.
VITE_ADSENSE_CLIENT_ID=
