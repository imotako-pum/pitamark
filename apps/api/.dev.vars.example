# Local development secrets for `wrangler dev`. Copy this file to `.dev.vars`
# (gitignored) and fill in the values. Never commit `.dev.vars`.
#
# Production secrets MUST be injected via `wrangler secret put NAME` instead
# of committing them anywhere.

# HS256 JWT signing secret for password-protected room tokens.
# Generate one with:  node -e "console.log(crypto.randomBytes(48).toString('base64url'))"
# Minimum 32 bytes recommended.
ROOM_TOKEN_SECRET="change-me-to-a-32-byte-or-longer-random-string"

# Cloudflare Turnstile siteverify secret. Phase 7 introduces invisible
# Turnstile on `POST /rooms`; the dev value below is the documented
# "always passes" test key, safe to commit.
# Production: `wrangler secret put TURNSTILE_SECRET_KEY` with the real
# secret from the Cloudflare dashboard's Turnstile widget.
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# When "true", Turnstile siteverify is skipped. Use only in dev / CI to
# avoid contacting the live endpoint. Production MUST stay "false"
# (the wrangler.toml `[vars]` default).
#
# Phase 7.5 production runbook (operator only — once per environment):
#   1. wrangler r2 bucket create snap-share-images
#   2. wrangler kv namespace create IMAGE_BLOCKLIST   # paste id into wrangler.toml
#   3. wrangler secret put ROOM_TOKEN_SECRET           # `openssl rand -base64 48`
#   4. wrangler secret put TURNSTILE_SECRET_KEY        # CF dashboard widget secret
#   5. update wrangler.toml [vars] TURNSTILE_SITE_KEY  # CF dashboard widget site key
#   6. cd apps/api && pnpm wrangler deploy
# See docs/observability.md for post-deploy validation.
BYPASS_TURNSTILE="true"

# Phase 7.6: When "true", every `withRateLimit` middleware short-circuits
# and lets the request through. Use only in dev / E2E so the production
# limit (5/60s on POST /rooms) does not block rapid local testing —
# Playwright runs in particular create 14+ rooms in parallel within a
# 60s window. Production MUST stay "false" (the wrangler.toml `[vars]`
# default). Strict-string compare: only the exact string "true" triggers
# bypass; "1" / "yes" / "TRUE" do NOT.
BYPASS_RATE_LIMIT="true"

# `wrangler dev` 時に API を叩いてよいブラウザ origin の allowlist。
# `.dev.vars` は wrangler.toml `[vars]` を**完全に置換**（マージしない）ので、
# 本番ホスト + localhost の dev origin を両方ここに書く必要がある。
# エントリ形式（完全オリジン / `*.suffix`）は `apps/api/src/lib/cors.ts` 参照。
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173,https://snap-share.pages.dev,*.snap-share.pages.dev"
