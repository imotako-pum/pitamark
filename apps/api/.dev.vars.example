# Local development secrets for `wrangler dev`. Copy this file to `.dev.vars`
# and fill in the values. `.dev.vars` is gitignored; never commit it.
#
# Production: inject via `wrangler secret put ROOM_TOKEN_SECRET` instead.

# HS256 JWT signing secret for password-protected room tokens.
# Generate one with:  node -e "console.log(crypto.randomBytes(48).toString('base64url'))"
# Minimum 32 bytes recommended.
ROOM_TOKEN_SECRET="change-me-to-a-32-byte-or-longer-random-string"
